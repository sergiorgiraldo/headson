  json: "\" 1st non-empty\\n2nd non-empty 3rd non-empty \"\n"
  dump: "' 1st non-empty\n\n  2nd non-empty 3rd non-empty '\n"
  emit: "' 1st non-empty\n\n  2nd non-empty 3rd non-empty '\n"
