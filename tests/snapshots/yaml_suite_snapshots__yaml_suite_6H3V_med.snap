---
- name: Backslashes in singlequotes
  from: "@perlpunk"
  tags: scalar single
  yaml: "'foo: bar\\': baz'\n"
  tree: "+STR\n +DOC\n  +MAP\n   =VAL 'foo: bar\\\\\n   =VAL :baz'\n  -MAP\n -DOC\n-STR\n"
  json: "{\n  \"foo: bar\\\\\": \"baz'\"\n}\n"
  dump: "'foo: bar\\': baz'\n"
