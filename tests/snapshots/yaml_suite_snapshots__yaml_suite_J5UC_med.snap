- name: Multiple Pair Block Mapping
  from: "https://github.com/ingydotnet/yaml-pegex-pm/blob/master/test/mapping.tml"
  tags: mapping
  yaml: "foo: blue\nbar: arrr\nbaz: jazz\n"
